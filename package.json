{
  "name": "epreuve-web",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run prisma:generate -w @troov/api",
    "db:migrate": "npm run prisma:migrate -w @troov/api",
    "db:studio": "npm run prisma:studio -w @troov/api",
    "db:validate": "npm run prisma:validate -w @troov/api",
    "db:seed": "npm run prisma:seed -w @troov/api",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}
